<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Initialize animations with a slight delay to ensure DOM is ready
    setTimeout(() => {
      initServicesAnimations();
      splitAndAnimateText();
    }, 100);

    // Refresh ScrollTrigger when page is fully loaded
    window.addEventListener("load", () => {
      ScrollTrigger.refresh();
    });
  });

  function splitAndAnimateText() {
    // Add responsive margin function
    const getResponsiveMargin = () => {
      const vw = Math.max(
        document.documentElement.clientWidth || 0,
        window.innerWidth || 0
      );

      if (vw < 640) {
        return "0.35rem"; 
      } else if (vw < 1024) {
        return "0.45rem";
      } else {
        return "0.55rem";
      }
    };

    // Split heading text
    const heading = document.querySelector("#service-heading");
    if (heading) {
      // ... same text splitting logic as in AboutWhy component ...
    }

    // ... Same approach for descriptions and other text elements ...
  }

  function initServicesAnimations() {
    // Main animation timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#service-heading",
        start: "top 80%",
      },
    });

    tl.from("#service-heading", { y: 30, opacity: 0, duration: 0.7 })
      .to(".description-animation", { y: 0, opacity: 1, duration: 0.7 }, "-=0.4")
      .from(
        ".service-card",
        {
          y: 50,
          opacity: 0,
          duration: 0.5,
          stagger: 0.1,
        },
        "-=0.2"
      );

    // Add hover effect for cards
    document.querySelectorAll(".grid > div").forEach((card) => {
      card.addEventListener("mouseenter", () => {
        gsap.to(card, { y: -5, duration: 0.3 });
      });

      card.addEventListener("mouseleave", () => {
        gsap.to(card, { y: 0, duration: 0.3 });
      });
    });
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
  });
</script>