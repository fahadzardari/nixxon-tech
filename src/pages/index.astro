---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.jsx";  // Make sure extension is .jsx
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import '../styles/global.css';
---

<Layout title="NixxonTech">
  <main class="min-h-screen">
    <Navbar />
    <Hero client:load />
    <section>
      <div class="container mx-auto">
        <h2 class="text-3xl font-bold text-center mt-10">Welcome to NixxonTech</h2>
        <p class="text-center mt-5 text-lg">
          We are a team of developers who are passionate about creating web applications that are both functional and beautiful.
        </p>
      </div>
    </section>

    <Footer/>
  </main>
</Layout>
