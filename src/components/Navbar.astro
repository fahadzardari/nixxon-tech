---
import { Image } from "astro:assets";
import Logo from "../assets/logo.webp";
const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about-us" },
  { label: "Services", href: "/services" },
  { label: "Contact", href: "/contact-us" },
];

// Get current path for active link highlighting
const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="bg-transparent fixed w-screen z-50 transition-all duration-300"
>
  <div class="app-max-width px-4">
    <nav
      class="flex justify-between items-center h-16"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/">
          <Image src={Logo} alt="Logo" class="h-8 w-auto" />
        </a>
      </div>

      <!-- Desktop Menu -->
      <ul class="hidden md:flex space-x-8 list-none">
        {
          navItems.map((item) => {
            const isActive =
              (item.href === "/" && currentPath === "/") ||
              (item.href !== "/" && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "transition duration-300",
                    "text-white hover:text-[#39D0FF]",
                    { "text-[#39D0FF] font-medium nav-active": isActive },
                  ]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden text-white hover:text-[#39D0FF]"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile Menu Aside -->
<aside
  id="mobile-menu"
  class="fixed top-0 -right-full w-64 h-full bg-white shadow-lg transition-transform duration-300 ease-in-out z-50"
  aria-label="Mobile navigation"
>
  <nav class="h-full pt-16 pb-4 px-4">
    <button
      id="mobile-menu-close"
      class="absolute top-4 right-4 text-gray-700 hover:text-blue-600"
      aria-label="Close mobile menu"
    >
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
    <ul class="list-none space-y-4">
      {
        navItems.map((item) => {
          const isActive =
            (item.href === "/" && currentPath === "/") ||
            (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block py-2 transition duration-300",
                  "text-gray-700 hover:text-[#39D0FF]",
                  { "text-[#39D0FF] font-medium": isActive },
                ]}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</aside>

<script>
  import { gsap } from "gsap";

  const navbar = document.getElementById("navbar");
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenuClose = document.getElementById("mobile-menu-close");
  const mobileMenu = document.getElementById("mobile-menu");

  // Toggle mobile menu function
  function toggleMenu(show: boolean) {
    if (!mobileMenu || !mobileMenuButton) return;

    if (show) {
      mobileMenu.classList.remove("-right-full");
      mobileMenu.classList.add("right-0");
      mobileMenuButton.setAttribute("aria-expanded", "true");
    } else {
      mobileMenu.classList.add("-right-full");
      mobileMenu.classList.remove("right-0");
      mobileMenuButton.setAttribute("aria-expanded", "false");
    }
  }

  mobileMenuButton?.addEventListener("click", () => toggleMenu(true));
  mobileMenuClose?.addEventListener("click", () => toggleMenu(false));

  // Close menu when clicking outside
  document.addEventListener("click", (e) => {
    if (
      mobileMenu &&
      !mobileMenu.contains(e.target as Node) &&
      mobileMenuButton &&
      !mobileMenuButton.contains(e.target as Node)
    ) {
      toggleMenu(false);
    }
  });

  // Handle scroll-based navbar background
  function handleScroll() {
    const scrollY = window.scrollY;

    if (navbar) {
      if (scrollY > 50) {
        // When scrolled, add background
        if (!navbar.classList.contains("scrolled")) {
          gsap.to(navbar, {
            backgroundColor: "rgba(19, 24, 33, 0.85)",
            backdropFilter: "blur(8px)",
            boxShadow: "0 4px 20px rgba(0, 0, 0, 0.15)",
            duration: 0.3,
            onComplete: () => {
              navbar.classList.add("scrolled");
            },
          });
        }
      } else {
        // When at top, remove background
        if (navbar.classList.contains("scrolled")) {
          gsap.to(navbar, {
            backgroundColor: "transparent",
            backdropFilter: "blur(0px)",
            boxShadow: "none",
            duration: 0.3,
            onComplete: () => {
              navbar.classList.remove("scrolled");
            },
          });
        }
      }
    }
  }

  // Add scroll event listener
  window.addEventListener("scroll", handleScroll);

  // Run once on page load to set initial state
  document.addEventListener("DOMContentLoaded", handleScroll);
</script>

<style>
  /* Style for active navigation link */
  .nav-active {
    color: #39d0ff;
  }

  /* Additional styles for scrolled navbar if needed */
  .scrolled {
    backdrop-filter: blur(8px);
  }
</style>
