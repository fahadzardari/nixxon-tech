---
import Image from "astro/components/Image.astro";
import IntroImage from "../../../assets/services/digital-marketing/digital-marketing-intro.png";
import Heading from "../../common/Heading.astro";
---

<section class="py-8 md:py-16 relative" id="digital-marketing-intro-section">
  <!-- Centered container for alignment -->
  <div
    class="app-max-width w-full flex flex-col lg:flex-row justify-between items-center"
  >
    <!-- Left content with negative margin to extend to screen edge -->
    <div
      class="w-full order-2 lg:order-1 md:ml-[calc(-1*(100vw-100%)/2)]"
      id="digital-marketing-image-container"
    >
      <Image
        src={IntroImage}
        alt="Digital Marketing Services Intro"
        title="Digital Marketing Services Intro"
        class="w-full my-2 md:my-16"
        id="digital-marketing-intro"
        loading="lazy"
      />
    </div>
    <!-- Right content -->
    <div
      class="w-full lg:w-1/2 flex flex-col space-y-4 py-8 md:py-0 lg:pl-8 order-1 lg:order-2"
      id="digital-marketing-intro-content"
    >
      <Heading>
        <h2 class="text-3xl md:text-4xl" id="digital-marketing-heading">
          GET AHEAD OF COMPETITION & LEAD THE CHARTS
        </h2>
      </Heading>
      <p
        class="text-base md:text-[16px] text-[#2a2111]"
        id="digital-marketing-paragraph"
      >
        Unleash your company's potential with our tactical performance marketing solutions. Drive conversions, generate quality leads, and expand your customer base through targeted campaigns and data-driven strategies. Outperform the competition and achieve remarkable growth, profitability, and ROI with our tailored approach.
      </p>
      <button
        class="w-fit inline-block px-8 md:px-12 py-3 leading-5 bg-primary-blue rounded-full text-white text-base md:text-lg transition
        shadow-md shadow-primary-blue/50 hover:shadow-sm hover:shadow-primary-blue/80"
        id="cta-button-digital-marketing"
      >
        Let's Talk
      </button>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Make sure button is visible by default
  document.querySelector("#cta-button-digital-marketing").style.opacity = "1";

  // Create a timeline that triggers when the section is in view
  const introTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#digital-marketing-intro-section",
      start: "top 70%",
      toggleActions: "play none none reset", // Changed to reset on scroll out
    },
  });

  // Determine if desktop or mobile
  const isDesktop = window.innerWidth >= 1024;

  // Add animations to the timeline with responsive behavior
  introTl
    // Image animation - slides in from left on desktop, up on mobile
    .from("#digital-marketing-intro", {
      x: isDesktop ? -50 : 0,
      y: isDesktop ? 0 : 30,
      opacity: 0,
      duration: 1,
      ease: "power2.out",
    })

    // Heading animation - slides up and fades in
    .from(
      "#digital-marketing-heading",
      {
        y: 30,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.6"
    )

    // Paragraph animation - fade in with slight upward movement
    .from(
      "#digital-marketing-paragraph",
      {
        y: 20,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.5"
    )

    // Button animation - modified to ensure visibility
    .fromTo(
      "#cta-button-digital-marketing",
      {
        scale: 0.9,
        opacity: 0,
      },
      {
        scale: 1,
        opacity: 1,
        duration: 0.6,
        ease: "back.out(1.5)",
        clearProps: "opacity,scale", // Important: clears properties after animation
      },
      "-=0.4"
    );

  // Add hover animation for the button
  const ctaButton = document.querySelector("#cta-button-digital-marketing");
  if (ctaButton) {
    ctaButton.addEventListener("mouseenter", () => {
      gsap.to("#cta-button-digital-marketing", {
        scale: 1.05,
        duration: 0.3,
        ease: "power1.out",
      });
    });

    ctaButton.addEventListener("mouseleave", () => {
      gsap.to("#cta-button-digital-marketing", {
        scale: 1,
        duration: 0.3,
        ease: "power1.out",
      });
    });
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
  });
</script>