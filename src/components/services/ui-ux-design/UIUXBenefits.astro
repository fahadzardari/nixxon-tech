---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="text-4xl" id="web-dev-benefits-heading">
      Our UI & UX design process
    </h2>
  </Heading>
  <div class="relative flex space-x-4 mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="guy-leaning-art"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-8 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="benefits-list"
    >
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Customer Request:</h4>
        <p>
          We start by fully understanding your specific requirements, goals, and
          target market in order to ensure that our design aligns with your
          vision and commercial agenda.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Detailed Specs & Cost Estimates:
        </h4>
        <p>
          We provide a comprehensive inspection of the project's scope, budget,
          and schedule to guarantee transparency and understanding right from
          the beginning.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Prototyping and UX/UI Design:</h4>
        <p>
          Wireframes and prototypes are created in order to conceptualize the
          website's structure, layout, and interactions. We adjust the design as
          needed to deliver an aesthetically beautiful and intuitive user
          interface in response to your feedback.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Frontend & Backend Development:
        </h4>
        <p>
          Our talented developers realize the concept by putting the frontend
          components into practice and connecting them with reliable backend
          capabilities, guaranteeing smooth functionality and performance.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">QA & Testing:</h4>
        <p>
          We carry out thorough quality assurance testing to find and fix any
          flaws, guaranteeing a perfect user experience on many platforms and
          browsers.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Delivery:</h4>
        <p>
          After development and testing are finished, we provide the finished
          website and offer help and support during the launch period to
          guarantee a seamless transition and a productive deployment.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Split heading text for character animation
    const headingText = new SplitType("#web-dev-benefits-heading", {
      types: "words",
      tagName: "span",
    });

    // Create timeline for animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#web-dev-benefits-heading",
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.words, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      stagger: 0.05,
      ease: "power2.out",
    });

    // Illustration animation
    tl.to(
      "#guy-leaning-art",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Staggered list items animation
    tl.to(
      ".benefit-item",
      {
        opacity: 1,
        x: 0,
        duration: 0.7,
        stagger: 0.15,
        ease: "power2.out",
      },
      "-=0.5"
    );

    // Add hover animation for Read More links
    const readMoreLinks = document.querySelectorAll(".read-more-link");

    readMoreLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          x: 5,
          duration: 0.3,
          ease: "power1.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          x: 0,
          duration: 0.3,
          ease: "power1.out",
        });
      });
    });
  });
</script>

<style>
  /* Initial states for animations */
  #guy-leaning-art {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  .read-more-link {
    transition: color 0.2s ease;
    display: inline-block;
  }

  .read-more-link:hover {
    color: #0056b3; /* Slightly darker blue on hover */
  }
</style>
