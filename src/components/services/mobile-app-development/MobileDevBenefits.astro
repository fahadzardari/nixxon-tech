---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="font-medium" id="mobile-dev-process-heading">
      Our Mobile App Development Process
    </h2>
  </Heading>
  <p class="text-[#2a2111] text-xs md:text-sm canvas:text-base 2xl:text-lg my-4 mobile-dev-description-animation">
    We follow a structured approach to mobile app development that ensures quality, 
    efficiency, and alignment with your business goals at every stage.
  </p>
  <div class="relative flex space-x-4 mt-8 md:mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="nixxon-illustration"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-4 md:space-y-8 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="benefits-list"
    >
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Customer Request:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          To provide the groundwork for the project, we start the mobile app
          development process by learning about the needs of the customer and
          obtaining insightful information.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Detailed Specs & Cost Estimates:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          To ensure openness and compatibility with the client's budget and
          goals, we offer a comprehensive examination of exact specifications
          together with a comprehensive cost estimation.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Prototyping and UX/UI Design:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          We translate concepts into aesthetically pleasing and easily navigable
          interfaces through prototype and UI/UX design, guaranteeing a smooth
          user experience.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Frontend & Backend Development:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          Using the newest technology, our knowledgeable staff precisely carries
          out frontend and backend development to create dependable and scalable
          mobile apps.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Testing:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          To ensure a smooth functionality, we perform strict testing and
          quality control analysis.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Delivery:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          Once completed, we provide the final mobile app ready to impact the
          users on a big scale.
        </p>
      </li>
      <li class="flex flex-col space-y-2 md:space-y-4 benefit-item opacity-0">
        <h4 class="text-base md:text-lg lg:text-xl canvas:text-[22px] 2xl:text-3xl font-semibold">
          Support:
        </h4>
        <p class="text-xs md:text-sm canvas:text-base 2xl:text-lg 3xl:text-xl">
          Our continuous support and maintenance keeps the app in check and
          optimized for prolonged use.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Initialize animations with a slight delay to ensure DOM is ready
    setTimeout(() => {
      initAnimations();
      splitAndAnimateText();
    }, 100);

    // Refresh ScrollTrigger when page is fully loaded
    window.addEventListener("load", () => {
      ScrollTrigger.refresh(true);
    });
  });

  // Helper function to get responsive paragraph margins based on screen size
  function getResponsiveParagraphMargin() {
    const vw = Math.max(
      document.documentElement.clientWidth || 0,
      window.innerWidth || 0
    );
    
    // Increased margins at each breakpoint for better readability
    if (vw < 480) {
      return "0.32em"; // Extra margin for very small mobile screens
    } else if (vw < 640) {
      return "0.28em"; // More spacing for small mobile screens
    } else if (vw < 768) {
      return "0.24em"; // Medium spacing for larger mobile screens
    } else if (vw < 1024) {
      return "0.22em"; // Spacing for tablets
    } else {
      return "0.2em";  // Original spacing for desktop
    }
  }

  // Function to split and animate text incrementally (matching AboutWhy)
  function splitAndAnimateText() {
    // Add responsive margin function
    const getResponsiveMargin = () => {
      // Use viewport width to determine margin
      const vw = Math.max(
        document.documentElement.clientWidth || 0,
        window.innerWidth || 0
      );

      if (vw < 640) {
        return "0.35rem"; // Margin on mobile
      } else if (vw < 1024) {
        return "0.45rem"; // Margin on tablets
      } else {
        return "0.55rem"; // Margin on desktops
      }
    };

    // Split heading text
    const heading = document.querySelector("#mobile-dev-process-heading");
    if (heading) {
      // Save original content
      const originalContent = heading.innerHTML;

      try {
        // Extract the text
        const headingText = heading.textContent.trim();
        const responsiveMargin = getResponsiveMargin();

        // Process heading
        const words = headingText.split(" ");
        let newContent = "";

        // Create wrapped words with responsive margins
        words.forEach((word, index) => {
          const isLastWord = index === words.length - 1;
          newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
            <span class="word-inner" style="display:inline-block; transform:translateY(30px); opacity:0;">${word}</span>
          </span>`;
        });

        heading.innerHTML = newContent;
        heading.style.opacity = 1;

        // Animate heading words
        const headingWords = heading.querySelectorAll(".word-inner");
        gsap.to(headingWords, {
          scrollTrigger: {
            trigger: heading,
            start: "top 85%",
            end: "top 65%",
            scrub: 0.6,
          },
          y: 0,
          opacity: 1,
          stagger: 0.04,
          ease: "power2.inOut",
        });

        // Update margins on resize
        window.addEventListener("resize", () => {
          const newMargin = getResponsiveMargin();
          const wordSpans = heading.querySelectorAll(".split-word");

          wordSpans.forEach((span, index) => {
            if (index < words.length - 1) {
              span.style.marginRight = newMargin;
            }
          });
        });
      } catch (error) {
        console.error("Heading split error:", error);
        heading.innerHTML = originalContent;
      }
    }

    // Animate description paragraph
    const description = document.querySelector(".mobile-dev-description-animation");
    if (description) {
      const originalContent = description.textContent;

      try {
        // Use the responsive margin for better spacing
        const responsiveMargin = getResponsiveParagraphMargin();

        // Normalize and split text
        const normalizedText = description.textContent.replace(/\s+/g, " ").trim();
        const words = normalizedText.split(" ");
        let newContent = "";

        // Create wrapped words with responsive margins
        words.forEach((word, index) => {
          const isLastWord = index === words.length - 1;
          newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
            <span class="word-inner paragraph-word" style="display:inline-block; transform:translateY(20px); opacity:0;">${word}</span>
          </span>`;
        });

        description.innerHTML = newContent;

        // Animate paragraph words
        const paragraphWords = description.querySelectorAll(".word-inner");
        gsap.to(paragraphWords, {
          scrollTrigger: {
            trigger: description,
            start: "top 90%",
            end: "center 75%",
            scrub: 0.7,
          },
          y: 0,
          opacity: 1,
          stagger: 0.015,
          ease: "power1.inOut",
        });
      } catch (error) {
        console.error("Description split error:", error);
        description.textContent = originalContent;
      }
    }

    // Split and animate benefits section
    const benefitItems = document.querySelectorAll(".benefit-item");

    benefitItems.forEach((item, itemIndex) => {
      // Process heading
      const itemHeading = item.querySelector("h4");
      if (itemHeading) {
        const originalHeadingContent = itemHeading.textContent;

        try {
          // Responsive margin for headings
          const responsiveMargin = window.innerWidth < 768 ? "0.15em" : "0.3em";

          // Split heading into words
          const words = itemHeading.textContent
            .replace(/\s+/g, " ")
            .trim()
            .split(" ");
          let newContent = "";

          // Create wrapped words with responsive margins
          words.forEach((word, index) => {
            const isLastWord = index === words.length - 1;
            newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
              <span class="word-inner" style="display:inline-block; transform:translateY(25px); opacity:0;">${word}</span>
            </span>`;
          });

          itemHeading.innerHTML = newContent;

          // Animate heading words
          const headingWords = itemHeading.querySelectorAll(".word-inner");
          gsap.to(headingWords, {
            scrollTrigger: {
              trigger: item,
              start: "top 85%",
              end: "top 75%",
              scrub: 0.6,
            },
            y: 0,
            opacity: 1,
            stagger: 0.03,
            ease: "power2.out",
          });
        } catch (error) {
          console.error("Benefit heading split error:", error);
          itemHeading.textContent = originalHeadingContent;
        }
      }

      // Process paragraph
      const paragraph = item.querySelector("p");
      if (paragraph) {
        const originalContent = paragraph.textContent;

        try {
          // Use responsive margin for better spacing
          const responsiveMargin = getResponsiveParagraphMargin();

          // Normalize and split text
          const normalizedText = paragraph.textContent
            .replace(/\s+/g, " ")
            .trim();
          const words = normalizedText.split(" ");
          let newContent = "";

          // Create wrapped words with responsive margins
          words.forEach((word, index) => {
            const isLastWord = index === words.length - 1;
            newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
              <span class="word-inner paragraph-word" style="display:inline-block; transform:translateY(20px); opacity:0;">${word}</span>
            </span>`;
          });

          paragraph.innerHTML = newContent;

          // Animate paragraph words with gentler timing
          const paragraphWords = paragraph.querySelectorAll(".word-inner");
          gsap.to(paragraphWords, {
            scrollTrigger: {
              trigger: paragraph,
              start: "top 90%",
              end: "center 75%",
              scrub: 0.7,
            },
            y: 0,
            opacity: 1,
            stagger: 0.015,
            ease: "power1.inOut",
          });
        } catch (error) {
          console.error("Paragraph split error:", error);
          paragraph.textContent = originalContent;
        }
      }
    });
  }

  // Update paragraph word spacing on resize
  function updateParagraphSpacing() {
    const newMargin = getResponsiveParagraphMargin();
    const splitWords = document.querySelectorAll(".benefit-item p .split-word, .mobile-dev-description-animation .split-word");
    
    splitWords.forEach(word => {
      word.style.marginRight = newMargin;
    });
  }

  function initAnimations() {
    // Staggered entrance for benefit items
    gsap.to(".benefit-item", {
      scrollTrigger: {
        trigger: "#benefits-list",
        start: "top 85%",
        end: "bottom 60%",
        scrub: 0.8,
      },
      opacity: 1,
      x: 0,
      stagger: 0.1,
      duration: 0.7,
      ease: "power2.out",
    });

    // Illustration animation
    gsap.to("#nixxon-illustration", {
      scrollTrigger: {
        trigger: "#nixxon-illustration",
        start: "top 85%",
        end: "center 70%",
        scrub: 0.6,
      },
      opacity: 1,
      x: 0,
      duration: 0.8,
      ease: "power2.inOut",
    });

    // Add subtle parallax to illustration for depth
    gsap.to("#nixxon-illustration", {
      scrollTrigger: {
        trigger: "#nixxon-illustration",
        start: "top bottom",
        end: "bottom top",
        scrub: true,
      },
      y: "-5%",
      ease: "none",
    });
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
    updateParagraphSpacing();
  });
</script>

<style>
  /* Initial states for animations */
  #nixxon-illustration {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  /* Additional spacing for paragraphs on smaller screens */
  @media (max-width: 768px) {
    .benefit-item p, .mobile-dev-description-animation {
      line-height: 1.6; /* Increased line height for better readability */
      letter-spacing: 0.01em; /* Slight letter spacing */
    }
    
    .paragraph-word {
      padding: 0.02em 0; /* Add vertical padding to words */
    }
  }
  
  /* Extra spacing for very small screens */
  @media (max-width: 480px) {
    .benefit-item p, .mobile-dev-description-animation {
      line-height: 1.7;
      letter-spacing: 0.015em;
    }
  }
</style>
