---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="text-4xl" id="mobile-dev-process-heading">
      Our Mobile App Development Process
    </h2>
  </Heading>
  <div class="relative flex space-x-4 mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="guy-leaning-art"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-6 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="mobile-dev-process-list"
    >
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Customer Request:</h4>
        <p>
          To provide the groundwork for the project, we start the mobile app
          development process by learning about the needs of the customer and
          obtaining insightful information.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Detailed Specs & Cost Estimates:
        </h4>
        <p>
          To ensure openness and compatibility with the client's budget and
          goals, we offer a comprehensive examination of exact specifications
          together with a comprehensive cost estimation.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Prototyping and UX/UI Design:</h4>
        <p>
          We translate concepts into aesthetically pleasing and easily navigable
          interfaces through prototype and UI/UX design, guaranteeing a smooth
          user experience.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Frontend & Backend Development:
        </h4>
        <p>
          Using the newest technology, our knowledgeable staff precisely carries
          out frontend and backend development to create dependable and scalable
          mobile apps.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Testing:</h4>
        <p>
          To ensure a smooth functionality, we perform strict testing and
          quality control analysis.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Delivery:</h4>
        <p>
          Once completed, we provide the final mobile app ready to impact the
          users on a big scale.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Support:</h4>
        <p>
          Our continuous support and maintenance keeps the app in check and
          optimized for prolonged use.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Split heading text for character animation
    const headingText = new SplitType("#mobile-dev-process-heading", {
      types: "words",
      tagName: "span",
    });

    // Create timeline for animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#mobile-dev-process-heading",
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.words, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      stagger: 0.05,
      ease: "power2.out",
    });

    // Illustration animation
    tl.to(
      "#guy-leaning-art",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Staggered list items animation
    document.querySelectorAll(".benefit-item").forEach((item, index) => {
      gsap.to(item, {
        scrollTrigger: {
          trigger: item,
          start: "top 85%", // Adjust this value to control when animation starts
          toggleActions: "play none none none",
        },
        opacity: 1,
        x: 0,
        duration: 0.7,
        ease: "power2.out",
      });
    });


    // Add hover animation for Read More links
    const readMoreLinks = document.querySelectorAll(".read-more-link");

    readMoreLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          x: 5,
          duration: 0.3,
          ease: "power1.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          x: 0,
          duration: 0.3,
          ease: "power1.out",
        });
      });
    });
  });
</script>

<style>
  /* Initial states for animations */
  #guy-leaning-art {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  .read-more-link {
    transition: color 0.2s ease;
    display: inline-block;
  }

  .read-more-link:hover {
    color: #0056b3; /* Slightly darker blue on hover */
  }
</style>
