---
import Art from "../../../assets/services/web-dev/art.png";
---

<section
  id="hero-section"
  class="hero bg-fixed bg-no-repeat bg-cover relative flex items-center justify-center px-4 md:px-16 min-h-screen w-full pt-16 overflow-hidden"
>
  <div
    class="absolute inset-0 bg-radial-[at_50%] opacity-70 from-[#1E1504]/5 to-black"
  >
  </div>

  <!-- Container with relative positioning -->
  <div
    class="app-max-width relative md:h-[60vh] flex md:flex-row items-center w-full"
  >
    <!-- Left Side Text - Front Layer -->
    <div
      id="hero-text"
      class="relative z-50 opacity-0 w-full md:w-1/2 text-white"
    >
      <div class="w-full relative">
        <h1 class="text-4xl md:text-5xl font-bold capitalize">
          Grow Your Business Potentially Through Our Advanced Website
          Development Solution.
        </h1>
        <a
          href="/contact"
          id="hero-cta"
          class="mt-6 inline-block px-8 py-3 border border-primary-blue rounded-full text-white text-sm md:text-lg transition
           shadow-md shadow-primary-blue/50 hover:shadow-xl hover:shadow-primary-blue/80
           hover:scale-105 duration-300"
        >
          Let's Talk
        </a>
      </div>
    </div>

    <!-- Right Side Image - Absolute positioning to extend beyond container -->
    <div
      id="hero-image"
      class="hidden md:block absolute right-0 top-0 bottom-0 w-2/3 z-0 opacity-0"
    >
      <div id="hero-image-container" class="w-full h-full">
        <img
          src={Art.src}
          alt="Web Development Illustration"
          class="w-full h-full object-contain object-right"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Register plugins
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Initialize based on screen size
    const updateLayout = () => {
      const isWideScreen = window.innerWidth >= 1536; // 2xl breakpoint
      const isDesktop = window.innerWidth >= 1024; // lg breakpoint

      // Adjust image width based on screen size
      if (document.querySelector("#hero-image")) {
        // Adjust width instead of position
        document.querySelector("#hero-image").style.width = isWideScreen
          ? "70%"
          : isDesktop
            ? "65%"
            : "60%";
        
        // Always set right to 0 to ensure alignment with viewport edge
        document.querySelector("#hero-image").style.right = "0";
      }
    };

    // Run on load and resize
    updateLayout();
    window.addEventListener("resize", updateLayout);

    // Initial animations (equivalent to initial + animate in Framer)
    gsap.fromTo(
      "#hero-text",
      {
        opacity: 0,
        x: -50,
      },
      {
        opacity: 1,
        x: 0,
        duration: 0.5,
        ease: "power2.out",
      }
    );

    gsap.fromTo(
      "#hero-image",
      {
        opacity: 0,
        x: 50,
      },
      {
        opacity: 1,
        x: 0,
        duration: 0.5,
        ease: "power2.out",
      }
    );

    // Scroll-based animations (equivalent to useTransform)
    ScrollTrigger.create({
      trigger: "#hero-section",
      start: "top top",
      end: "bottom top",
      scrub: true,
      onUpdate: (self) => {
        const progress = self.progress;

        // Text fade and movement (equivalent to textOpacity and textY)
        if (progress <= 0.5) {
          const opacity = 1 - progress * 2;
          const y = progress * -50;
          gsap.to("#hero-text", { opacity, y, duration: 0 });
        }

        // Image scale and rotation (equivalent to imageScale and imageRotate)
        if (progress <= 0.5) {
          const scale = 1 - progress * 0.15;
          const rotate = progress * -10;
          gsap.to("#hero-image", { scale, rotate, duration: 0 });
        }
      },
    });

    // Wave-like animation (infinite loop)
    // This replaces the waveAnimation from Framer Motion
    const waveTimeline = gsap.timeline({
      repeat: -1,
    });

    waveTimeline
      .to("#hero-image-container", {
        y: -15,
        rotate: 2,
        scale: 1.02,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: 0,
        rotate: 0,
        scale: 1,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: -10,
        rotate: -2,
        scale: 1.01,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: 0,
        rotate: 0,
        scale: 1,
        duration: 2.5,
        ease: "sine.inOut",
      });

    // Button pulse animation (replacing whileInView from Framer)
    gsap.to("#hero-cta", {
      scale: 1.05,
      duration: 0.75,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut",
    });

    // Add hover effect for CTA button
    const ctaButton = document.querySelector("#hero-cta");
    if (ctaButton) {
      // Pause the automatic animation on hover
      ctaButton.addEventListener("mouseenter", () => {
        // Kill any existing animations
        gsap.killTweensOf("#hero-cta");

        // Create hover animation
        gsap.to(ctaButton, {
          scale: 1.05,
          boxShadow: "0 10px 25px rgba(57, 208, 255, 0.7)",
          duration: 0.3,
        });
      });

      ctaButton.addEventListener("mouseleave", () => {
        // Restore default state
        gsap.to(ctaButton, {
          scale: 1,
          boxShadow: "0 5px 15px rgba(57, 208, 255, 0.5)",
          duration: 0.3,
          // Restart the pulse animation after hover
          onComplete: () => {
            gsap.to("#hero-cta", {
              scale: 1.05,
              duration: 0.75,
              repeat: -1,
              yoyo: true,
              ease: "power1.inOut",
            });
          },
        });
      });
    }
  });
</script>

<style>
  /* Custom styles for extended image */
  .object-center-right {
    object-position: 60% center;
  }

  /* Add overflow hidden to main section to prevent horizontal scrollbar */
  section {
    overflow-x: hidden;
  }

  @media (min-width: 768px) {
    #hero-image {
      right: 0; /* Always align to the right edge of viewport */
    }
    
    #hero-image img {
      max-width: none;
      width: 100%;
    }
  }

  @media (min-width: 1280px) {
    /* Remove the negative right positioning */
    .object-center-right {
      object-position: 70% center;
    }
  }

  @media (min-width: 1536px) {
    /* Remove the negative right positioning */
  }
</style>
