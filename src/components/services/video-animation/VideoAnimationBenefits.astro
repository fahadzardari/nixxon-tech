---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="text-4xl" id="video-animation-process-heading">
      Our Video Animation Process
    </h2>
  </Heading>
  <div class="relative flex space-x-4 mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="guy-leaning-art"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-6 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="video-animation-process-list"
    >
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Customer Request:</h4>
        <p>
          Our ability to provide customized and outstanding outcomes is based on our thorough understanding of the customer's request and special requirements, which forms the basis of our video animation process.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Detailed Specs & Cost Estimates:
        </h4>
        <p>
          In order to provide a detailed cost estimate, we must acquire exact specifications and understand the needs of the customer for our video animation development process.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Initial Themes</h4>
        <p>
          After that, we work with the customer to develop preliminary concepts and themes that support their goals.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Story Board</h4>
        <p>
          Following approval of the concepts, we produce a thorough storyboard that describes the animation's visual plot and flow.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Animation</h4>
        <p>
          Our talented animators carefully bring the concept to life, paying special attention to every detail, using the finalized storyboard as a guide.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Voice Over</h4>
        <p>
          We use expert voice-over services to improve the animation by locating the ideal voice actor that can deliver the intended tone and message.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Delivery</h4>
        <p>
          Lastly, we make sure the client has an outstanding experience by providing the completed video animation in the format of their choice.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Split heading text for character animation
    const headingText = new SplitType("#video-animation-process-heading", {
      types: "chars",
      tagName: "span",
    });

    // Create timeline for animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#video-animation-process-heading",
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.chars, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      stagger: 0.02,
      ease: "power2.out",
    });

    // Illustration animation
    tl.to(
      "#guy-leaning-art",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Staggered list items animation
    tl.to(
      ".benefit-item",
      {
        opacity: 1,
        x: 0,
        duration: 0.7,
        stagger: 0.15,
        ease: "power2.out",
      },
      "-=0.5"
    );

    // Add hover animation for Read More links
    const readMoreLinks = document.querySelectorAll(".read-more-link");

    readMoreLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          x: 5,
          duration: 0.3,
          ease: "power1.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          x: 0,
          duration: 0.3,
          ease: "power1.out",
        });
      });
    });
  });
</script>

<style>
  /* Initial states for animations */
  #guy-leaning-art {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  .read-more-link {
    transition: color 0.2s ease;
    display: inline-block;
  }

  .read-more-link:hover {
    color: #0056b3; /* Slightly darker blue on hover */
  }
</style>
