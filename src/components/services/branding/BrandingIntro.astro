---
import Image from "astro/components/Image.astro";
import IntroImage from "../../../assets/services/branding/branding-intro.png";
import Heading from "../../common/Heading.astro";
---

<section
  class="app-max-width flex flex-col md:flex-row justify-between items-center space-y-8 md:space-y-0 md:space-x-12"
  id="branding-intro-section"
>
  <div
    class="ml-[calc(-1*(100vw-100%)/2)] w-full md:w-4/5"
    id="branding-image-container"
  >
    <Image
      src={IntroImage}
      alt="Branding Services Intro"
      title="Branding Services Intro"
      class="w-full my-16"
      id="branding-intro"
      loading="lazy"
    />
  </div>
  <div
    class="flex flex-col space-y-6 w-full md:w-2/5"
    id="branding-intro-content"
  >
    <Heading>
      <h2 class="text-4xl" id="branding-heading">
        Eye-catching identity design
      </h2>
    </Heading>
    <p
      class="text-[16px] text-[#2a2111] opacity-100"
      id="branding-intro-paragraph"
    >
      Our company is skilled in producing striking identity designs that
      encapsulate the spirit of our clients' businesses and make an impact. We
      create visually appealing and memorable brand identities that successfully
      convey our clients' essential message and values thanks to our expert
      graphic designers and painstaking attention to detail.
    </p>
    <button
      class="w-fit inline-block px-12 py-3 leading-5 bg-primary-blue rounded-full text-white text-lg transition
      shadow-md shadow-primary-blue/50 hover:shadow-sm hover:shadow-primary-blue/80 !opacity-100"
      id="cta-button-branding"
    >
      Let's Talk
    </button>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Create a timeline that triggers when the section is in view
  const introTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#branding-intro-section",
      start: "top 70%",
      toggleActions: "play none none none",
    },
  });

  // Add animations to the timeline
  introTl
    // Image animation - slides in from left with slight opacity effect
    .from("#branding-intro", {
      x: -50,
      opacity: 0,
      duration: 1,
      ease: "power2.out",
    })

    // Heading animation - slides up and fades in
    .from(
      "#branding-heading">,
      {
        y: 30,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.6"
    ) // Start slightly before the image animation finishes

    // Paragraph animation - fade in with slight upward movement
    .fromTo(
      "#branding-intro-paragraph",
      {
        y: 20,
        opacity: 0,
      },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
        clearProps: "all", // Important to clear properties after animation
      },
      "-=0.5"
    )

    // Button animation - subtle pop effect
    .from(
      "#cta-button-branding",
      {
        scale: 0.9,
        opacity: 0,
        duration: 0.6,
        ease: "back.out(1.5)",
      },
      "-=0.4"
    );

  // Add hover animation for the button
  const ctaButton = document.querySelector("#cta-button-branding");
  if (ctaButton) {
    ctaButton.addEventListener("mouseenter", () => {
      gsap.to("#cta-button-branding", {
        scale: 1.05,
        duration: 0.3,
        ease: "power1.out",
      });
    });

    ctaButton.addEventListener("mouseleave", () => {
      gsap.to("#cta-button-branding", {
        scale: 1,
        duration: 0.3,
        ease: "power1.out",
      });
    });
  }
</script>
