---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="text-4xl" id="branding-process-heading">
      Our Brand Design Process
    </h2>
  </Heading>
  <div class="relative flex space-x-4 mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="guy-leaning-art"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-6 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="branding-process-list"
    >
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Customer Request:</h4>
        <p>
          Prioritizing client demands helps us make sure we fully grasp their
          objectives and needs before moving on with the brand design process.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Detailed Specs & Cost Estimates:
        </h4>
        <p>
          To guarantee alignment and unambiguous expectations with our clients,
          we offer comprehensive specifications and an open and honest cost
          estimate.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">
          Initial Concepts & First Drafts
        </h4>
        <p>
          First concepts are created and first drafts are delivered as part of
          our brand design process so that clients may see and comment on the
          direction of their brand.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Revisions</h4>
        <p>
          In an effort to continuously improve the brand design and win over our
          clients' total happiness, we actively participate in revision cycles
          and actively solicit their input.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Customer Supports</h4>
        <p>
          After delivery, we continue to help our clients by answering any
          queries or issues they might have. This shows how committed we are to
          them.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Split heading text for character animation
    const headingText = new SplitType("#branding-process-heading", {
      types: "words",
      tagName: "span",
    });

    // Create timeline for animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#branding-process-heading",
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.words, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      stagger: 0.05,
      ease: "power2.out",
    });

    // Illustration animation
    tl.to(
      "#guy-leaning-art",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Staggered list items animation
    tl.to(
      ".benefit-item",
      {
        opacity: 1,
        x: 0,
        duration: 0.7,
        stagger: 0.15,
        ease: "power2.out",
      },
      "-=0.5"
    );

    // Add hover animation for Read More links
    const readMoreLinks = document.querySelectorAll(".read-more-link");

    readMoreLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          x: 5,
          duration: 0.3,
          ease: "power1.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          x: 0,
          duration: 0.3,
          ease: "power1.out",
        });
      });
    });
  });
</script>

<style>
  /* Initial states for animations */
  #guy-leaning-art {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  .read-more-link {
    transition: color 0.2s ease;
    display: inline-block;
  }

  .read-more-link:hover {
    color: #0056b3; /* Slightly darker blue on hover */
  }
</style>
