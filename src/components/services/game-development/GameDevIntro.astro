---
import Image from "astro/components/Image.astro";
import IntroImage from "../../../assets/services/game-development/game-dev-intro.png";
import Heading from "../../common/Heading.astro";
---

<section class="py-8 md:py-16 relative" id="game-dev-intro-section">
  <!-- Centered container for alignment -->
  <div
    class="app-max-width w-full flex flex-col lg:flex-row justify-between items-center"
  >
    <!-- Left content with negative margin to extend to screen edge -->
    <div
      class="w-full order-2 lg:order-1 md:ml-[calc(-1*(100vw-100%)/2)]"
      id="game-dev-image-container"
    >
      <Image
        src={IntroImage}
        alt="Game Development Services Intro"
        title="Game Development Services Intro"
        class="w-full my-2 md:my-16"
        id="game-dev-intro"
        loading="lazy"
      />
    </div>
    <!-- Right content -->
    <div
      class="w-full lg:w-1/2 flex flex-col space-y-4 py-8 md:py-0 lg:pl-8 order-1 lg:order-2"
      id="game-dev-intro-content"
    >
      <Heading>
        <h2 class="text-3xl md:text-4xl" id="game-dev-heading">
          TRANSFORMING IDEAS INTO EPIC GAMES
        </h2>
      </Heading>
      <p
        class="text-base md:text-[16px] text-[#2a2111]"
        id="game-dev-paragraph"
      >
        Concepts are expertly turned into graphically spectacular video games by NixxonTech. You can rely on us to provide amazing experiences that go beyond what's considered enjoyable and thrilling. Let us utilize your ideas to their fullest and produce games that enthrall players everywhere.
      </p>
      <button
        class="w-fit inline-block px-8 md:px-12 py-3 leading-5 bg-primary-blue rounded-full text-white text-base md:text-lg transition
        shadow-md shadow-primary-blue/50 hover:shadow-sm hover:shadow-primary-blue/80"
        id="cta-button-game-dev"
      >
        Let's Talk
      </button>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Make sure button is visible by default
  document.querySelector("#cta-button-game-dev").style.opacity = "1";

  // Create a timeline that triggers when the section is in view
  const introTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#game-dev-intro-section",
      start: "top 70%",
      toggleActions: "play none none reset", // Changed to reset on scroll out
    },
  });

  // Determine if desktop or mobile
  const isDesktop = window.innerWidth >= 1024;

  // Add animations to the timeline with responsive behavior
  introTl
    // Image animation - slides in from left on desktop, up on mobile
    .from("#game-dev-intro", {
      x: isDesktop ? -50 : 0,
      y: isDesktop ? 0 : 30,
      opacity: 0,
      duration: 1,
      ease: "power2.out",
    })

    // Heading animation - slides up and fades in
    .from(
      "#game-dev-heading",
      {
        y: 30,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.6"
    )

    // Paragraph animation - fade in with slight upward movement
    .from(
      "#game-dev-paragraph",
      {
        y: 20,
        opacity: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.5"
    )

    // Button animation - modified to ensure visibility
    .fromTo(
      "#cta-button-game-dev",
      {
        scale: 0.9,
        opacity: 0,
      },
      {
        scale: 1,
        opacity: 1,
        duration: 0.6,
        ease: "back.out(1.5)",
        clearProps: "opacity,scale", // Important: clears properties after animation
      },
      "-=0.4"
    );

  // Add hover animation for the button
  const ctaButton = document.querySelector("#cta-button-game-dev");
  if (ctaButton) {
    ctaButton.addEventListener("mouseenter", () => {
      gsap.to("#cta-button-game-dev", {
        scale: 1.05,
        duration: 0.3,
        ease: "power1.out",
      });
    });

    ctaButton.addEventListener("mouseleave", () => {
      gsap.to("#cta-button-game-dev", {
        scale: 1,
        duration: 0.3,
        ease: "power1.out",
      });
    });
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
  });
</script>