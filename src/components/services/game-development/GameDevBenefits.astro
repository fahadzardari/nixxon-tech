---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import ArtWhy from "../../../assets/about-us/art-why.webp";
---

<section class="app-max-width py-16">
  <Heading>
    <h2 class="text-4xl" id="game-dev-process-heading">
      Our Game Development Process
    </h2>
  </Heading>
  <div class="relative flex space-x-4 mt-16 w-full">
    <Image
      src={ArtWhy}
      alt="Leaning Art"
      title="Guy Leaning"
      class="hidden md:block z-0 left-0 w-1/3 opacity-0 h-fit my-auto"
      id="guy-leaning-art"
    />
    <ul
      class="list-none flex justify-between flex-col space-y-6 text-[#0b1125] md:border-l md:border-l-[#e0e0e0] md:px-4 md:w-[75%]"
      id="game-dev-process-list"
    >
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Plan</h4>
        <p>
          Before we begin development, we carefully plan out every facet of the
          game, such as the goals, gameplay, and general aesthetic.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Concept Art, Asset Production</h4>
        <p>
          Concept art and asset production are the following stages, where the
          game's vision is brought to life with gorgeous graphics, character
          designs, and locations.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Game Development</h4>
        <p>
          Our talented development team codes and combines the features,
          gameplay mechanisms, and user interfaces while the game is being
          developed.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Test</h4>
        <p>
          By finding and fixing any bugs or flaws, extensive testing guarantees
          that the game runs smoothly and offers a flawless and seamless gaming
          experience.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Launch</h4>
        <p>
          We go into the exciting launch phase, where the game is made available
          to eager players on numerous platforms, following a period of intense
          tuning and testing.
        </p>
      </li>
      <li class="flex flex-col space-y-4 benefit-item opacity-0">
        <h4 class="text-[22px] font-semibold">Maintenance</h4>
        <p>
          We are determined to provide the game with frequent updates, bug
          fixes, and improvements so that users can find it engaging and
          pleasurable even after it has been released.
        </p>
      </li>
    </ul>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Wait for DOM content to be fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    // Split heading text for character animation
    const headingText = new SplitType("#game-dev-process-heading", {
      types: "words",
      tagName: "span",
    });

    // Create timeline for animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#game-dev-process-heading",
        start: "top 80%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.words, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      stagger: 0.05,
      ease: "power2.out",
    });

    // Illustration animation
    tl.to(
      "#guy-leaning-art",
      {
        opacity: 1,
        x: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Staggered list items animation
    document.querySelectorAll(".benefit-item").forEach((item, index) => {
      gsap.to(item, {
        scrollTrigger: {
          trigger: item,
          start: "top 85%", // Adjust this value to control when animation starts
          toggleActions: "play none none none",
        },
        opacity: 1,
        x: 0,
        duration: 0.7,
        ease: "power2.out",
      });
    });


    // Add hover animation for Read More links
    const readMoreLinks = document.querySelectorAll(".read-more-link");

    readMoreLinks.forEach((link) => {
      link.addEventListener("mouseenter", () => {
        gsap.to(link, {
          x: 5,
          duration: 0.3,
          ease: "power1.out",
        });
      });

      link.addEventListener("mouseleave", () => {
        gsap.to(link, {
          x: 0,
          duration: 0.3,
          ease: "power1.out",
        });
      });
    });
  });
</script>

<style>
  /* Initial states for animations */
  #guy-leaning-art {
    transform: translateX(-20px);
  }

  .benefit-item {
    transform: translateX(20px);
  }

  .read-more-link {
    transition: color 0.2s ease;
    display: inline-block;
  }

  .read-more-link:hover {
    color: #0056b3; /* Slightly darker blue on hover */
  }
</style>
