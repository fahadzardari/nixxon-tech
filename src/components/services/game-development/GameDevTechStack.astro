---
import Heading from "../../common/Heading.astro";
import Image from "astro/components/Image.astro";
import UnityIcon from "../../../assets/services/game-development/unity.png";
import UnrealIcon from "../../../assets/services/game-development/unreal.png";
import BlanderIcon from "../../../assets/services/video-animation/blander.png";
import MayaIcon from "../../../assets/services/video-animation/maya.png";
import MaxIcon from "../../../assets/services/video-animation/max.png";
---

<section class="app-max-width py-16">
  <div class="game-dev-tech-stack">
    <Heading>
      <h2 class="text-4xl" id="game-dev-tech-stack-heading">
        Technology Stack
      </h2>
    </Heading>
    <p class="text-[#2a2111] text-[16px] my-4">
      Get a full technology stack including Unity 3D and Unreal Engine together with the newest advancements in VR, AR, AI, and multiplayer networking in order to create state-of-the-art, high-performing gaming experiences.
    </p>
  </div>

  <div
    class="flex space-x-8 justify-between items-center game-dev-tech-stack-container"
  >
    <Image
      src={UnityIcon}
      alt="Unity"
      title="Unity"
      class="w-full tech-icon"
      id="game-dev-unity-icon"
      loading="lazy"
    />
    <Image
      src={UnrealIcon}
      alt="Unreal Engine"
      title="Unreal Engine"
      class="w-full tech-icon"
      id="game-dev-unreal-icon"
      loading="lazy"
    />
    <Image
      src={BlanderIcon}
      alt="Blender"
      title="Blender"
      class="w-full tech-icon"
      id="game-dev-blender-icon"
      loading="lazy"
    />
    <Image
      src={MayaIcon}
      alt="Maya"
      title="Maya"
      class="w-full tech-icon"
      id="game-dev-maya-icon"
      loading="lazy"
    />
    <Image
      src={MaxIcon}
      alt="3ds Max"
      title="3ds Max"
      class="w-full tech-icon"
      id="game-dev-max-icon"
      loading="lazy"
    />
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Fade in the content on scroll
    gsap.from(".game-dev-tech-stack", {
      opacity: 0,
      y: 20,
      duration: 0.7,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".game-dev-tech-stack",
        start: "top 80%", // Triggers when the top of the element hits 80% from the top of viewport
        toggleActions: "play none none none",
      },
    });

    // Staggered reveal for tech icons on scroll
    gsap.from(".tech-icon", {
      opacity: 0,
      y: 15,
      scale: 0.95,
      duration: 0.5,
      stagger: 0.1,
      ease: "back.out(1.2)",
      scrollTrigger: {
        trigger: ".game-dev-tech-stack-container",
        start: "top 80%", // Triggers when the top of the element hits 80% from the top of viewport
        toggleActions: "play none none none",
      },
    });
  });
</script>