---
import { Image } from "astro:assets";
import Heading from "../common/Heading.astro";
import AboutUsVideoImage from "../../assets/home/about/video.png";
import GIFImage from "../../assets/home/about/gif.gif";
---

<section class="app-max-width py-16" id="about-section">
  <Heading>
    <h2 id="about-us-heading" class="text-4xl font-medium">
      Get Ahead of the Competition <br />
      <span class="text-primary-blue">and Lead the Charts</span>
    </h2>
  </Heading>

  <p class="my-4" id="about-paragraph">
    Reach out beyond the crowd and leave a lasting impression with our
    assistance. You can boost revenue, bring in more customers, and fortify your
    brand with our tailored solutions. With confidence, your vision can be
    fulfilled because of our experience.
  </p>

  <Image
    src={AboutUsVideoImage}
    alt={"About Us"}
    class={"w-full max-h-[640px] mx-auto my-8"}
    id="main-about-image"
  />

  <div
    class="flex flex-col md:flex-row space-y-6 md:space-y-0 md:space-x-6 items-center justify-between mt-16"
    id="about-bottom-section"
  >
    <div class="w-full md:w-1/2">
      <Image
        src={GIFImage}
        alt={"GIF Image"}
        class={"w-full h-auto rounded-tr-[23px] rounded-bl-[23px] rounded-tl-[90px] rounded-br-[90px]"}
        id={"gif-image"}
      />
    </div>
    <div
      id="right-column-about-us"
      class="w-full md:w-1/2 flex flex-col space-y-4"
    >
      <h4 class="text-lg">About Us</h4>
      <h3 class="text-primary-blue text-4xl font-medium capitalize">
        Mission to elevate business growth
      </h3>
      <p class="text-[#2A2111] text-[16px]">
        NixxonTech is a premier Digital agency, offering superior business
        advancement solutions across diverse sectors. Our goal is to enhance
        progress, innovation, and outcomes, driven by a mission to elevate
        business growth.
      </p>
      <a href="#" class="text-primary-blue">
        Read More <span>&rarr;</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register plugins
  gsap.registerPlugin(ScrollTrigger);

  // Make sure elements are visible initially (prevents white space issue on mobile)
  document.addEventListener("DOMContentLoaded", () => {
    // Set initial visibility
    gsap.set("#about-section *", { visibility: "visible", opacity: 1 });
    
    // Initialize animations after a slight delay to ensure proper rendering
    setTimeout(initAboutAnimations, 100);
    
    // Force a refresh when page is fully loaded
    window.addEventListener("load", () => {
      ScrollTrigger.refresh(true);
    });
  });

  function initAboutAnimations() {
    // Detect mobile viewport
    const isMobile = window.innerWidth < 768;
    
    // Mobile-specific trigger offsets
    const mobileOffset = isMobile ? "90%" : "80%";

    // Main heading animation
    const heading = document.querySelector("#about-us-heading");
    if (heading) {
      const splitHeading = new SplitType(heading, { types: "lines" });
      gsap.from(splitHeading.lines, {
        scrollTrigger: {
          trigger: heading,
          start: `top ${mobileOffset}`,
          once: isMobile, // Mobile animation runs only once
        },
        opacity: 0,
        y: 30, // Reduced movement on mobile
        stagger: 0.2,
        duration: 0.8,
      });

      // Highlight blue text
      gsap.from("#about-us-heading span", {
        scrollTrigger: { 
          trigger: heading,
          start: `top ${mobileOffset}`,
          once: isMobile,
        },
        opacity: 0,
        y: 20,
        delay: 0.6,
        duration: 1,
        ease: "back.out(1.7)",
      });
    }

    // Paragraph fade-in
    gsap.from("#about-paragraph", {
      scrollTrigger: {
        trigger: "#about-paragraph",
        start: `top ${mobileOffset}`,
        once: isMobile,
      },
      opacity: 0,
      y: 30,
      duration: 0.8,
      delay: 0.2,
    });

    // Main image reveal
    const mainImage = document.querySelector("#main-about-image");
    if (mainImage) {
      gsap.from(mainImage, {
        scrollTrigger: {
          trigger: mainImage,
          start: `top ${mobileOffset}`,
          once: isMobile,
        },
        scale: 1.05,
        opacity: 0,
        duration: 1.2,
        ease: "power2.out",
      });
    }

    // Bottom section animations
    const gifImage = document.querySelector("#gif-image");
    if (gifImage) {
      // GIF image reveal
      gsap.from(gifImage, {
        scrollTrigger: {
          trigger: "#about-bottom-section",
          start: `top ${mobileOffset}`,
          once: isMobile,
        },
        x: isMobile ? -20 : -50, // Smaller movement on mobile
        opacity: 0,
        duration: 1,
        ease: "power3.out",
      });

      // Add subtle floating animation - only on desktop
      if (!isMobile) {
        gsap.to(gifImage, {
          scrollTrigger: {
            trigger: gifImage,
            start: `top ${mobileOffset}`,
          },
          y: "10px",
          duration: 2,
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut",
          delay: 1,
        });
      }
    }

    // Right column content staggered reveal
    const rightColumn = document.querySelector("#right-column-about-us");
    if (rightColumn) {
      const elements = rightColumn.querySelectorAll("h4, h3, p, a");
      gsap.from(elements, {
        scrollTrigger: {
          trigger: rightColumn,
          start: `top ${mobileOffset}`,
          once: isMobile,
        },
        y: 30,
        opacity: 0,
        stagger: 0.15,
        duration: 0.8,
        ease: "power2.out",
      });

      // Special animation for the "Read More" link
      const readMoreLink = rightColumn.querySelector("a");
      if (readMoreLink) {
        readMoreLink.addEventListener("mouseenter", () => {
          gsap.to(readMoreLink, {
            color: "#0056b3",
            duration: 0.3,
          });
          gsap.to(readMoreLink.querySelector("span"), {
            x: 5,
            duration: 0.3,
          });
        });

        readMoreLink.addEventListener("mouseleave", () => {
          gsap.to(readMoreLink, {
            color: "#1141D3",
            duration: 0.3,
          });
          gsap.to(readMoreLink.querySelector("span"), {
            x: 0,
            duration: 0.3,
          });
        });
      }
    }
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
  });
</script>