---
import Input from "./Input.astro"
---

<form class="py-4 flex flex-col space-y-16">
  <h1 class="text-2xl font-semibold">
    Have a Plan? Let's Get Started
  </h1>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <Input type="text" placeholder="Name" />
    <Input type="email" placeholder="Email" />
    <Input type="tel" placeholder="Phone Number" />
    <Input type="text" placeholder="Country" />
    <Input type="number" placeholder="Budget" />
    <Input type="text" placeholder="Services Looking For" />
    <Input type="text" placeholder="How Soons you are willing to get started" />
    <Input type="text" placeholder="Message" />
  </div>

  <button type="submit" class="border w-fit border-primary-blue rounded-full px-6 py-2" >
    Send Message Now
  </button>
</form>