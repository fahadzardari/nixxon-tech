---
import Art from "../../assets/art.webp";
import Image from "astro/components/Image.astro";
---

<section
  id="hero-section"
  class="hero bg-fixed bg-no-repeat bg-cover relative flex items-center justify-center px-4 md:px-16 min-h-screen w-full pt-16"
>
  <div
    class="absolute inset-0 bg-radial-[at_50%] opacity-70 from-[#1E1504]/5 to-black"
  >
  </div>

  <!-- Left Side Text -->
  <div
    class="app-max-width relative md:h-[60vh] flex items-center lg:items-end w-full"
  >
    <!-- Text Content (Front Layer) -->
    <div
      id="hero-text"
      class="relative z-50 opacity-0 w-full lg:w-3/5 text-white"
    >
      <div class="w-full relative">
        <h1 class="text-4xl md:text-5xl font-bold capitalize">
          We at NixxonTech are dedicated to helping businesses succeed online.
        </h1>
        <p class="mt-4 text-sm md:text-md xl:text-xl opacity-80">
          Whether you run a small business, startup or large corporation, we are
          here to support you. Our committed staff combines cutting-edge
          technology, data-driven strategies, and creativity to get the desired
          results.
        </p>
        <a
          href="/contact"
          id="hero-cta"
          class="mt-6 inline-block px-8 py-3 border border-primary-blue rounded-full text-white text-sm md:text-lg transition
         shadow-md shadow-primary-blue/50 hover:shadow-xl hover:shadow-primary-blue/80
         hover:scale-105 duration-300"
        >
          Let's Talk
        </a>
      </div>
    </div>

    <!-- Right Side Image (Back Layer) -->
    <div
      id="hero-image"
      class="hidden lg:block absolute right-0 top-0 bottom-0 w-2/3 z-0 opacity-0"
    >
      <div id="hero-image-container" class="w-full h-full">
        <Image
          src={Art}
          alt={"3D VR Person"}
          class={"w-full h-full object-contain object-right"}
          loading={"eager"}
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Register plugins
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Initial animations (equivalent to initial + animate in Framer)
    gsap.fromTo(
      "#hero-text",
      {
        opacity: 0,
        x: -50,
      },
      {
        opacity: 1,
        x: 0,
        duration: 0.5,
        ease: "power2.out",
      }
    );

    gsap.fromTo(
      "#hero-image",
      {
        opacity: 0,
        x: 50,
      },
      {
        opacity: 1,
        x: 0,
        duration: 0.5,
        ease: "power2.out",
      }
    );

    // Scroll-based animations (equivalent to useTransform)
    ScrollTrigger.create({
      trigger: "#hero-section",
      start: "top top",
      end: "bottom top",
      scrub: true,
      onUpdate: (self) => {
        const progress = self.progress;

        // Text fade and movement (equivalent to textOpacity and textY)
        if (progress <= 0.5) {
          const opacity = 1 - progress * 2;
          const y = progress * -50;
          gsap.to("#hero-text", { opacity, y, duration: 0 });
        }

        // Image scale and rotation (equivalent to imageScale and imageRotate)
        if (progress <= 0.5) {
          const scale = 1 - progress * 0.15;
          const rotate = progress * -10;
          gsap.to("#hero-image", { scale, rotate, duration: 0 });
        }
      },
    });

    // Wave-like animation (infinite loop)
    // This replaces the waveAnimation from Framer Motion
    const waveTimeline = gsap.timeline({
      repeat: -1,
    });

    waveTimeline
      .to("#hero-image-container", {
        y: -15,
        rotate: 2,
        scale: 1.02,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: 0,
        rotate: 0,
        scale: 1,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: -10,
        rotate: -2,
        scale: 1.01,
        duration: 2.5,
        ease: "sine.inOut",
      })
      .to("#hero-image-container", {
        y: 0,
        rotate: 0,
        scale: 1,
        duration: 2.5,
        ease: "sine.inOut",
      });

    // Button pulse animation (replacing whileInView from Framer)
    gsap.to("#hero-cta", {
      scale: 1.05,
      duration: 0.75,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut",
    });

    // Add hover effect for CTA button
    const ctaButton = document.querySelector("#hero-cta");
    if (ctaButton) {
      // Pause the automatic animation on hover
      ctaButton.addEventListener("mouseenter", () => {
        // Kill any existing animations
        gsap.killTweensOf("#hero-cta");

        // Create hover animation
        gsap.to(ctaButton, {
          scale: 1.05,
          boxShadow: "0 10px 25px rgba(57, 208, 255, 0.7)",
          duration: 0.3,
        });
      });

      ctaButton.addEventListener("mouseleave", () => {
        // Restore default state
        gsap.to(ctaButton, {
          scale: 1,
          boxShadow: "0 5px 15px rgba(57, 208, 255, 0.5)",
          duration: 0.3,
          // Restart the pulse animation after hover
          onComplete: () => {
            gsap.to("#hero-cta", {
              scale: 1.05,
              duration: 0.75,
              repeat: -1,
              yoyo: true,
              ease: "power1.inOut",
            });
          },
        });
      });
    }
  });
</script>
