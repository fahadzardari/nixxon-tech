---
import ServiceDetail from "./ServiceDetail.astro";
import WebDevImage from "../../assets/home/services/web-dev.svg";

const services = [
  {
    title: "Web Development",
    description:
      "Creating user-friendly, quickly loaded websites is crucial to delivering a top-notch experience. A well-developed website makes sure that your design is applied correctly, that your content is accessible, and that it runs smoothly on many browsers and devices. It enables users to interact with your brand successfully, browse with ease, and locate pertinent information with ease.",
    image: WebDevImage,
    alt: "Web Development",
    link: "/services/web-development",
  },
  {
    title: "Mobile Development",
    description:
      "We build mobile apps that are fast, secure, and easy to manage.",
    image: WebDevImage,
    alt: "Mobile Development",
    link: "/services/mobile-app-development",
  },
  {
    title: "UI/UX Design",
    description:
      "We design user interfaces that are easy to use and visually appealing.",
    image: WebDevImage,
    alt: "UI/UX Design",
    link: "/services/ui-ux-design",
  },
  {
    title: "Digital Marketing",
    description:
      "We help you reach your target audience and grow your business.",
    image: WebDevImage,
    alt: "Digital Marketing",
    link: "/services/digital-marketing",
  },
  {
    title: "SEO",
    description:
      "We help you rank higher on search engines and get more traffic.",
    image: WebDevImage,
    alt: "SEO",
    link: "/services/digital-marketing",
  },
  {
    title: "Game Development",
    description: "We build games that are fun, engaging, and addictive.",
    image: WebDevImage,
    alt: "Game Development",
    link: "/services/game-development",
  },
  {
    title: "Business Strategy",
    description: "We help you grow your business and reach your goals.",
    image: WebDevImage,
    alt: "Business Strategy",
    link: "/services/digital-marketing",
  },
  {
    title: "DevOps",
    description:
      "We help you automate your development and deployment processes.",
    image: WebDevImage,
    alt: "DevOps",
    link: "/services/devops-services",
  },
];
---

<section
  id="services"
  class="app-max-width py-16 relative"
  aria-labelledby="services-heading"
>
  <div class="services-sticky-container">
    <h2
      id="services-heading"
      class="text-xl md:text-2xl lg:text-3xl canvas:text-[38px] 2xl:text-[42px] 3xl:text-[46px] font-medium mb-8 md:mb-16 opacity-0"
    >
      Your Full Service
      <span class="text-primary-blue neon-glow">Digital Partner</span>
    </h2>
    <div
      class="flex flex-col md:flex-row md:border-l md:border-l-[#E0E0E0] md:space-x-4"
    >
      <nav
        class="service-tabs-nav w-full md:w-1/3 overflow-x-auto mb-8 md:mb-0"
        aria-label="Services navigation"
      >
        <ul
          role="tablist"
          class="flex flex-nowrap md:flex-col space-x-3 md:space-x-0 md:space-y-4 w-full"
        >
          {
            services.map((service, index) => (
              <li
                role="presentation"
                class="service-tab-item opacity-0 flex-shrink-0"
              >
                <button
                  id={`tab-${index}`}
                  role="tab"
                  aria-controls={`panel-${index}`}
                  aria-selected={index === 0 ? "true" : "false"}
                  class:list={[
                    "service-tab",
                    "text-sm",
                    "md:text-base lg:text-base xl:text-lg canvas:text-2xl",
                    "cursor-pointer",
                    "font-medium",
                    "py-2",
                    "md:py-4",
                    "px-4",
                    "lg:px-8 xl:px-16",
                    "w-full",
                    "text-center",
                    "md:text-left",
                    "transition-colors",
                    "duration-300",
                    "rounded-full",
                    "whitespace-nowrap",
                    "md:rounded-none",
                  ]}
                  data-index={index}
                >
                  {service.title}
                </button>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="w-full md:w-2/3" id="service-details-container">
        {
          services.map((service, index) => (
            <article
              id={`panel-${index}`}
              role="tabpanel"
              aria-labelledby={`tab-${index}`}
              class:list={[
                "service-detail",
                "flex",
                "items-center",
                "justify-center",
                "opacity-0",
                {
                  hidden: index !== 0,
                },
              ]}
            >
              <ServiceDetail service={service} />
            </article>
          ))
        }
      </div>
    </div>
  </div>
  <!-- Spacer div to create scrolling area -->
  <div id="services-scroll-spacer" class=""></div>
</section>

<style>
  .hidden {
    display: none;
  }

  /* Initial states for animations */
  .service-tab-item {
    transform: translateX(-20px);
  }

  #services-heading {
    transform: translateY(20px);
  }

  .service-detail {
    transform: translateY(20px);
  }

  .service-tab {
    position: relative;
    overflow: hidden;
  }

  .service-tab::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background-color: #39d0ff;
    transition: width 0.3s ease;
  }

  .service-tab:hover::after {
    width: 100%;
  }

  /* Sticky styling */
  .services-sticky-container {
    position: relative;
    z-index: 2;
  }

  /* Ensure each panel takes full height within container */
  .service-detail {
    width: 100%;
    min-height: 100%;
  }

  /* Apply transition for smooth panel changes */
  [role="tabpanel"] {
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  // Split and animate service descriptions in the active panel
  const animateActivePanel = () => {
    const activePanel = document.querySelector(
      "[role='tabpanel']:not(.hidden)"
    );
    if (!activePanel) return;

    // Find the description paragraph in the active panel
    const description = activePanel.querySelector("p");
    if (!description || description.querySelector(".split-word")) return;

    const originalContent = description.textContent;

    try {
      // Normalize and split description
      const normalizedText = description.textContent
        .replace(/\s+/g, " ")
        .trim();
      const words = normalizedText.split(" ");
      let newContent = "";

      // Create wrapped words with subtle initial transformation
      words.forEach((word) => {
        newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; margin-right:6px;">
            <span class="word-inner" style="display:inline-block; transform:translateY(20px); opacity:0;">${word}</span>
          </span>`;
      });

      description.innerHTML = newContent;

      // Animate the words
      const descriptionWords = description.querySelectorAll(".word-inner");
      gsap.to(descriptionWords, {
        scrollTrigger: {
          trigger: description,
          start: "top 90%",
          end: "center 75%",
          scrub: 0.7,
        },
        y: 0,
        opacity: 1,
        stagger: 0.015,
        ease: "power1.inOut",
      });
    } catch (error) {
      console.error("Description split error:", error);
      description.textContent = originalContent;
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    // Initialize text splitting and animations
    setTimeout(() => {
      initServicesAnimations();
      splitAndAnimateText();
      setupStickyServices();
    }, 100);

    // Refresh ScrollTrigger when page is fully loaded
    window.addEventListener("load", () => {
      ScrollTrigger.refresh(true);
    });
  });

  function setupStickyServices() {
    const servicesSection = document.getElementById("services");
    const stickyContainer = document.querySelector(
      ".services-sticky-container"
    );
    const tabs = document.querySelectorAll("[role='tab']");
    const panels = document.querySelectorAll("[role='tabpanel']");
    const spacerDiv = document.getElementById("services-scroll-spacer");

    const isMobile = window.innerWidth < 768;
    const viewportHeight = window.innerHeight;
    const viewportWidth = window.innerWidth;

    // Calculate how tall the spacer needs to be to accommodate all panels
    const panelCount = panels.length;

    // Define panel spacing first so we can use it to calculate spacer height
    const getPanelSpacing = () => {
      if (viewportWidth < 768) {
        return viewportHeight * 0.95; // Slightly reduced spacing for mobile
      } else {
        return viewportHeight * 0.9; // Original spacing for desktop
      }
    };

    // Calculate spacer height based on panel spacing
    const getSpacerHeight = () => {
      const spacing = getPanelSpacing();
      // For mobile: use exact panel count minus a small buffer to reduce empty space
      if (viewportWidth < 480) {
        // Last panel needs less space as we don't need to scroll past it
        return (panelCount - 1) * spacing + viewportHeight * 0.7;
      }
      // For larger screens: use panel count with a buffer for smoother scrolling
      else if (viewportWidth < 768) {
        return (panelCount - 1) * spacing + viewportHeight * 0.75;
      } else {
        return panelCount * spacing - 100; // Slightly reduce desktop height too
      }
    };

    const spacerHeight = getSpacerHeight();
    console.log("Spacer height:", spacerHeight);

    // Set spacer height
    spacerDiv.style.height = `${spacerHeight}px`;

    // Create a ScrollTrigger for each panel transition
    let sectionPin;

    // Function to update scroll spacer height on resize
    const updateSpacerHeight = () => {
      const updatedHeight = getSpacerHeight();
      spacerDiv.style.height = `${updatedHeight}px`;

      // Refresh ScrollTrigger to update pinning dimensions
      if (sectionPin) {
        sectionPin.refresh();
      }
    };

    // Listen for window resize events
    window.addEventListener("resize", updateSpacerHeight);

    // Create pin for the section
    sectionPin = ScrollTrigger.create({
      trigger: servicesSection,
      start: "top top",
      end: () => `+=${spacerHeight}`,
      pin: stickyContainer,
      pinSpacing: false,
      // markers: true,
    });

    // Create scroll-driven tab transitions with adjusted spacing for mobile
    panels.forEach((panel, index) => {
      // Skip the first panel as it's shown by default
      if (index === 0) return;

      const prevPanel = panels[index - 1];
      const tab = tabs[index];

      // Use consistent spacing based on the same function as spacer height
      const panelSpacing = getPanelSpacing();

      // Adjust trigger points for each panel
      const getTriggerPositions = () => {
        // Special case for last panel to ensure it triggers before the spacer ends
        if (index === panelCount - 1) {
          return {
            // Start the last panel transition earlier
            start: `top+=${index * panelSpacing - viewportHeight * 0.15} top`,
            // End the last panel transition sooner
            end: `top+=${index * panelSpacing + viewportHeight * 0.1} top`,
          };
        }

        return {
          start: `top+=${index * panelSpacing - viewportHeight * 0.1} top`,
          end: `top+=${index * panelSpacing + viewportHeight * 0.2} top`,
        };
      };

      const triggerPositions = getTriggerPositions();

      ScrollTrigger.create({
        trigger: spacerDiv,
        start: () => triggerPositions.start,
        end: () => triggerPositions.end,
        onEnter: () => {
          activateTabAndPanel(index);
        },
        onEnterBack: () => {
          activateTabAndPanel(index - 1);
        },
        // markers: true,
      });
    });

    // Function to activate a specific tab and panel with snappy transition
    function activateTabAndPanel(index) {
      // Update active tab styling and ARIA attributes
      tabs.forEach((t, i) => {
        // Kill any existing GSAP animations on tabs
        gsap.killTweensOf(t, "backgroundColor");

        if (i === index) {
          t.style.backgroundColor = "#39d0ff"; // Primary blue
          t.style.color = "#ffffff"; // White text
          t.setAttribute("aria-selected", "true");

          // Ensure mobile tab scrolls into view
          if (window.innerWidth < 768) {
            t.scrollIntoView({
              behavior: "smooth",
              inline: "center",
              block: "nearest",
            });
          }
        } else {
          t.style.backgroundColor = "transparent";
          t.style.color = "#1e1e1e";
          t.setAttribute("aria-selected", "false");
        }
      });

      // Hide all panels first
      panels.forEach((p, i) => {
        if (i !== index) {
          p.style.opacity = "0";
          p.style.transform = "translateY(20px)";
          p.classList.add("hidden");
          p.style.display = "none";
        }
      });

      // Show the active panel with a snappy transition
      const activePanel = panels[index];
      activePanel.classList.remove("hidden");
      activePanel.style.display = "flex";

      // Use GSAP for smoother animation
      gsap.to(activePanel, {
        opacity: 1,
        y: 0,
        duration: 0.3,
        ease: "power2.out",
        onComplete: () => {
          // Handle any post-animation tasks
          animateActivePanel();
        },
      });
    }

    // Initial activation of the first panel
    activateTabAndPanel(0);
  }

  function splitAndAnimateText() {
    // Split heading text
    const heading = document.querySelector("#services-heading");
    if (heading) {
      // Save original content
      const originalContent = heading.innerHTML;

      try {
        // Add responsive margin function
        const getResponsiveMargin = () => {
          // Use viewport width to determine margin
          const vw = Math.max(
            document.documentElement.clientWidth || 0,
            window.innerWidth || 0
          );

          if (vw < 640) {
            return "0.35rem"; // Increased margin on mobile
          } else if (vw < 1024) {
            return "0.45rem"; // Increased margin on tablets
          } else {
            return "0.55rem"; // Increased margin on desktops
          }
        };

        const responsiveMargin = getResponsiveMargin();

        // Use a more reliable approach to get the exact text content
        // Store original text for restoration
        const mainText = "Your Full Service";
        const spanContent = "Digital Partner";

        // Process main part of the heading - normalize whitespace to prevent duplication
        const words = mainText.split(" ");
        let newContent = "";

        // FIXED: Create wrapped words with responsive margins - apply margin directly
        words.forEach((word, index) => {
          const isLastWord = index === words.length - 1;
          newContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
            <span class="word-inner" style="display:inline-block; transform:translateY(30px); opacity:0;">${word}</span>
          </span>`;
        });

        // Create wrapped words for span part with responsive margins
        let newSpanContent = '<span class="text-primary-blue neon-glow">';
        const spanWords = spanContent.split(" ");

        spanWords.forEach((word, index) => {
          const isLastWord = index === spanWords.length - 1;
          newSpanContent += `<span class="split-word" style="display:inline-block; overflow:hidden; ${!isLastWord ? `margin-right: ${responsiveMargin}` : ""}">
            <span class="word-inner" style="display:inline-block; transform:translateY(30px); opacity:0;">${word}</span>
          </span>`;
        });

        newSpanContent += "</span>";

        // FIXED: Replace the heading content with correctly spaced content - use fixed margin
        heading.innerHTML =
          newContent +
          `<span style="display:inline-block; width:${responsiveMargin}; min-width:${responsiveMargin};"></span>` +
          newSpanContent;
        heading.style.opacity = 1;

        // FIXED: Update margins on resize with proper style setting
        window.addEventListener("resize", () => {
          const newMargin = getResponsiveMargin();

          // Update spacer between sections
          const spacerSpan = heading.querySelector("span[style*='width']");
          if (spacerSpan) {
            spacerSpan.style.width = newMargin;
            spacerSpan.style.minWidth = newMargin;
          }

          // Update all split words
          const wordSpans = heading.querySelectorAll(".split-word");
          const mainWordsCount = words.length;
          const spanWordsCount = spanWords.length;

          wordSpans.forEach((span, index) => {
            // Don't apply margin to the last word in each section
            if (
              index < mainWordsCount - 1 ||
              (index >= mainWordsCount &&
                index < mainWordsCount + spanWordsCount - 1)
            ) {
              span.style.marginRight = newMargin;
            }
          });
        });

        // Animate the heading words
        const headingWords = heading.querySelectorAll(".word-inner");
        gsap.to(headingWords, {
          scrollTrigger: {
            trigger: heading,
            start: "top 85%",
            end: "top 65%",
            scrub: 0.6,
          },
          y: 0,
          opacity: 1,
          stagger: 0.04,
          ease: "power2.inOut",
        });
      } catch (error) {
        console.error("Services heading split error:", error);
        // Restore original content if something goes wrong
        heading.innerHTML = originalContent;
        // Fallback animation
        gsap.to(heading, { opacity: 1, y: 0, duration: 0.8 });
      }
    }

    // Process active panel on initial load
    animateActivePanel();

    // Setup observer to detect panel changes for tab system
    const panelsContainer = document.getElementById(
      "service-details-container"
    );
    if (panelsContainer) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === "attributes" || mutation.type === "childList") {
            // When DOM changes, check if we need to animate a newly active panel
            animateActivePanel();
          }
        });
      });

      observer.observe(panelsContainer, {
        attributes: true,
        childList: true,
        subtree: true,
        attributeFilter: ["class", "style"],
      });
    }
  }

  function initServicesAnimations() {
    // Get all service tabs and panels
    const tabs = document.querySelectorAll("[role='tab']");
    const panels = document.querySelectorAll("[role='tabpanel']");

    // Staggered entrance for tabs (consistent with AboutUs animations)
    gsap.to(".service-tab-item", {
      scrollTrigger: {
        trigger: ".service-tabs-nav",
        start: "top 85%",
        end: "bottom 70%",
        scrub: 0.7,
      },
      opacity: 1,
      x: 0,
      stagger: 0.08,
      duration: 0.6,
      ease: "power2.out",
    });

    // First panel animation
    gsap.to("[role='tabpanel']:not(.hidden)", {
      scrollTrigger: {
        trigger: "#service-details-container",
        start: "top 85%",
        end: "bottom 75%",
        scrub: 0.8,
      },
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power2.out",
    });

    // Add click event listeners to tabs with animations
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // Get the index of the clicked tab
        const index = parseInt(tab.dataset.index);

        // Find currently active tab
        const currentActiveTab = document.querySelector(
          "[aria-selected='true']"
        );
        const currentActiveIndex = parseInt(currentActiveTab.dataset.index);

        // Don't animate if clicking the current tab
        if (currentActiveIndex === index) return;

        // Update active tab styling and ARIA attributes
        tabs.forEach((t, i) => {
          if (i === index) {
            // Kill any existing GSAP animations on this tab first
            gsap.killTweensOf(t, "backgroundColor");

            // Use direct style setting for more reliable control
            t.style.backgroundColor = "#39d0ff"; // Primary blue
            t.style.color = "#ffffff"; // White text for better contrast
            t.setAttribute("aria-selected", "true");

            // Add subtle pulse animation to selected tab
            gsap.to(t, {
              scale: 1.03,
              duration: 0.2,
              onComplete: () => gsap.to(t, { scale: 1, duration: 0.2 }),
            });
          } else {
            // Kill any existing GSAP animations on non-selected tabs
            gsap.killTweensOf(t, "backgroundColor");

            // Reset styles for non-selected tabs
            t.style.backgroundColor = "transparent";
            t.style.color = "#1e1e1e"; // Original text color
            t.setAttribute("aria-selected", "false");
          }
        });

        // Get current and new panels by their indices for reliable selection
        const currentPanel = document.getElementById(
          `panel-${currentActiveIndex}`
        );
        const newPanel = document.getElementById(`panel-${index}`);

        // Ensure we found both panels
        if (currentPanel && newPanel) {
          // Timeline for panel transition with improved smoothness
          const panelTl = gsap.timeline();

          // First, ensure new panel is ready but hidden
          newPanel.classList.remove("hidden");
          newPanel.style.display = "flex";
          newPanel.style.opacity = 0;
          newPanel.style.transform = "translateY(20px)";

          // Fade out current panel with smoother easing
          panelTl.to(currentPanel, {
            opacity: 0,
            y: -10,
            duration: 0.4,
            ease: "power1.inOut",
            onComplete: () => {
              // Hide current panel completely
              currentPanel.style.display = "none";
              currentPanel.classList.add("hidden");
            },
          });

          // Fade in new panel with smoother animation
          panelTl.to(newPanel, {
            opacity: 1,
            y: 0,
            duration: 0.5,
            ease: "power2.out",
            onComplete: () => {
              // Only animate the panel content, not the heading again
              animateActivePanel();
            },
          });
        }
      });

      // Add hover effect for tabs
      tab.addEventListener("mouseenter", () => {
        if (tab.getAttribute("aria-selected") !== "true") {
          gsap.to(tab, {
            backgroundColor: "rgba(57, 208, 255, 0.1)",
            duration: 0.3,
          });
        }
      });

      tab.addEventListener("mouseleave", () => {
        if (tab.getAttribute("aria-selected") !== "true") {
          gsap.to(tab, {
            backgroundColor: "transparent",
            duration: 0.3,
          });
        }
      });
    });

    // Set initial active tab styles directly
    const initialTab = document.querySelector("[aria-selected='true']");
    if (initialTab) {
      initialTab.style.backgroundColor = "#39d0ff";
      initialTab.style.color = "#ffffff";
    }

    // Set initial active tab styles
    tabs.forEach((tab) => {
      if (tab.getAttribute("aria-selected") === "true") {
        tab.style.backgroundColor = "#39d0ff"; // Primary blue
        tab.style.color = "#ffffff";
      } else {
        tab.style.backgroundColor = "transparent";
        tab.style.color = "#1e1e1e";
      }
    });
  }

  // Update animations on resize
  window.addEventListener("resize", () => {
    ScrollTrigger.refresh();
  });
</script>
