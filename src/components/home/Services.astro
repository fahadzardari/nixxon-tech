---
import ServiceDetail from "./ServiceDetail.astro";
const services = [
  {
    title: "Web Development",
    description: "We build websites that are fast, secure, and easy to manage.",
    image: "/assets/home/services/web-dev.svg",
    alt: "Web Development",
    link: "/web-development",
  },
  {
    title: "Mobile Development",
    description:
      "We build mobile apps that are fast, secure, and easy to manage.",
    image: "/assets/home/services/mobile-dev.svg",
    alt: "Mobile Development",
    link: "/mobile-development",
  },
  {
    title: "UI/UX Design",
    description:
      "We design user interfaces that are easy to use and visually appealing.",
    image: "/assets/home/services/ui-ux.svg",
    alt: "UI/UX Design",
    link: "/ui-ux-design",
  },
  {
    title: "Digital Marketing",
    description:
      "We help you reach your target audience and grow your business.",
    image: "/assets/home/services/digital-marketing.svg",
    alt: "Digital Marketing",
    link: "/digital-marketing",
  },
  {
    title: "SEO",
    description:
      "We help you rank higher on search engines and get more traffic.",
    image: "/assets/home/services/seo.svg",
    alt: "SEO",
    link: "/seo",
  },
  {
    title: "Game Development",
    description: "We build games that are fun, engaging, and addictive.",
    image: "/assets/home/services/game-dev.svg",
    alt: "Game Development",
    link: "/game-development",
  },
  {
    title: "Business Strategy",
    description: "We help you grow your business and reach your goals.",
    image: "/assets/home/services/business-strategy.svg",
    alt: "Business Strategy",
    link: "/business-strategy",
  },
  {
    title: "DevOps",
    description:
      "We help you automate your development and deployment processes.",
    image: "/assets/home/services/devops.svg",
    alt: "DevOps",
    link: "/devops",
  },
];
---

<section
  id="services"
  class="app-max-width py-16"
  aria-labelledby="services-heading"
>
  <h2 id="services-heading" class="text-4xl font-medium mb-16 opacity-0">
    Your Full Service
    <span class="text-primary-blue">Digital Partner</span>
  </h2>
  <div class="border-l border-l-[#E0E0E0] flex space-x-4">
    <nav class="flex flex-col space-y-4 w-1/3" aria-label="Services navigation">
      <ul role="tablist" class="flex flex-col space-y-4 w-full">
        {
          services.map((service, index) => (
            <li role="presentation" class="service-tab-item opacity-0">
              <button
                id={`tab-${index}`}
                role="tab"
                aria-controls={`panel-${index}`}
                aria-selected={index === 0 ? "true" : "false"}
                class:list={[
                  "service-tab",
                  "text-xl",
                  "text-[#1e1e1e]",
                  "cursor-pointer",
                  "font-medium",
                  "py-4",
                  "px-16",
                  "w-full",
                  "text-left",
                  "transition-colors duration-300",
                  {
                    "bg-primary-blue": index === 0,
                  },
                ]}
                data-index={index}
              >
                {service.title}
              </button>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="w-2/3" id="service-details-container">
      {
        services.map((service, index) => (
          <article
            id={`panel-${index}`}
            role="tabpanel"
            aria-labelledby={`tab-${index}`}
            class:list={[
              "service-detail",
              "flex",
              "items-center",
              "justify-center",
              "opacity-0",
              {
                hidden: index !== 0,
              },
            ]}
          >
            <ServiceDetail service={service} />
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hidden {
    display: none;
  }

  /* Initial states for animations */
  .service-tab-item {
    transform: translateX(-20px);
  }

  #services-heading {
    transform: translateY(20px);
  }

  .service-detail {
    transform: translateY(20px);
  }

  .service-tab {
    position: relative;
    overflow: hidden;
  }

  .service-tab::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background-color: #39d0ff;
    transition: width 0.3s ease;
  }

  .service-tab:hover::after {
    width: 100%;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  // Register ScrollTrigger plugin
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Initialize split text for heading
    const headingText = new SplitType("#services-heading", {
      types: "words",
      tagName: "span",
    });

    // Create main timeline for initial animations
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#services",
        start: "top 75%",
        toggleActions: "play none none none",
      },
    });

    // Heading animation
    tl.from(headingText.words, {
      opacity: 0,
      y: 30,
      stagger: 0.1,
      duration: 0.7,
      ease: "power2.out",
    });
    tl.to("#services-heading", { opacity: 1, y: 0, duration: 0 }, "<");

    // Tabs animation - staggered entrance
    tl.to(
      ".service-tab-item",
      {
        opacity: 1,
        x: 0,
        stagger: 0.075,
        duration: 0.6,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // First panel animation
    tl.to(
      "[role='tabpanel']:not(.hidden)",
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
      },
      "-=0.3"
    );

    // Get all service tabs
    const tabs = document.querySelectorAll("[role='tab']");
    const panels = document.querySelectorAll("[role='tabpanel']");

    // Add click event listeners to tabs with animations
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // Get the index of the clicked tab
        const index = parseInt(tab.dataset.index);

        // Find currently active tab
        const currentActiveTab = document.querySelector(
          "[aria-selected='true']"
        );
        const currentActiveIndex = parseInt(currentActiveTab.dataset.index);

        // Don't animate if clicking the current tab
        if (currentActiveIndex === index) return;

        // Update active tab styling and ARIA attributes
        tabs.forEach((t, i) => {
          if (i === index) {
            // Use direct style setting for more reliable control
            t.style.backgroundColor = "#39d0ff"; // Primary blue
            t.style.color = "#ffffff"; // White text for better contrast
            t.setAttribute("aria-selected", "true");

            // Add subtle pulse animation to selected tab
            gsap.to(t, {
              scale: 1.03,
              duration: 0.2,
              onComplete: () => gsap.to(t, { scale: 1, duration: 0.2 }),
            });
          } else {
            // Reset styles for non-selected tabs
            t.style.backgroundColor = "transparent";
            t.style.color = "#1e1e1e"; // Original text color
            t.setAttribute("aria-selected", "false");
          }
        });

        // *** IMPROVED PANEL TRANSITION ***
        // Get current and new panels by their indices for reliable selection
        const currentPanel = document.getElementById(
          `panel-${currentActiveIndex}`
        );
        const newPanel = document.getElementById(`panel-${index}`);

        // Ensure we found both panels
        if (currentPanel && newPanel) {
          // Timeline for panel transition
          const panelTl = gsap.timeline();

          // Fade out current panel
          panelTl.to(currentPanel, {
            opacity: 0,
            y: 10,
            duration: 0.3,
            ease: "power2.in",
            onComplete: () => {
              // Hide current panel
              currentPanel.classList.add("hidden");
              // Show new panel but still invisible (opacity 0)
              newPanel.classList.remove("hidden");
              newPanel.style.opacity = 0;
              newPanel.style.transform = "translateY(20px)";
            },
          });

          // Fade in new panel after the previous animation completes
          panelTl.to(newPanel, {
            opacity: 1,
            y: 0,
            duration: 0.5,
            ease: "power2.out",
          });
        }
      });

      // Add hover effect for tabs
      tab.addEventListener("mouseenter", () => {
        if (tab.getAttribute("aria-selected") !== "true") {
          gsap.to(tab, {
            backgroundColor: "rgba(57, 208, 255, 0.1)",
            duration: 0.3,
          });
        }
      });

      tab.addEventListener("mouseleave", () => {
        if (tab.getAttribute("aria-selected") !== "true") {
          gsap.to(tab, {
            backgroundColor: "transparent",
            duration: 0.3,
          });
        }
      });
    });

    // Set initial active tab styles directly
    const initialTab = document.querySelector("[aria-selected='true']");
    if (initialTab) {
      initialTab.style.backgroundColor = "#39d0ff";
      initialTab.style.color = "#ffffff";
    }
  });
</script>
