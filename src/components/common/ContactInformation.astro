---
import { Image } from "astro:assets";
import Art from "../../assets/contact-us/contact.svg";
import CallIcon from "../../assets/contact-us/call.png";
import EmailIcon from "../../assets/contact-us/email.png";
import LocationIcon from "../../assets/contact-us/location.png";
import FacebookIcon from "../../assets/contact-us/facebook.png";
import InstagramIcon from "../../assets/contact-us/instagram.png";
import LinkedInIcon from "../../assets/contact-us/linkedin.png";
import PinterestIcon from "../../assets/contact-us/pinterest.png";
import YoutubeIcon from "../../assets/contact-us/youtube.png";
---

<section class="flex flex-col md:flex-row items-center md:justify-between app-max-width py-8 md:py-16 px-4 md:px-0 gap-8 md:gap-0" id="contact-info-section">
  <div class="w-full md:w-3/4 flex flex-col space-y-8 md:space-y-12">
    <div>
      <h2 class="text-primary-blue text-2xl md:text-[38px] font-semibold" id="contact-heading">
        Contact Information
      </h2>
      <p class="text-base md:text-lg" id="contact-description">
        Fill up the form and Our Team will get back to you within 24 hours.
      </p>
    </div>
    <div class="flex flex-col md:flex-row md:space-x-6 space-y-6 md:space-y-0 text-base md:text-[18px] font-semibold" id="contact-details-container">
      <div class="contact-detail-item">
        <h3 class="text-primary-blue mb-2 md:mb-4">Call Us At:</h3>
        <p class="flex items-center space-x-2 font-medium">
          <Image src={CallIcon} alt="Call Icon" class="w-5 md:w-6 inline-block" />
          <a href="tel:+1234567890">+1 234 567 890</a>
        </p>
      </div>
      <div class="contact-detail-item">
        <h3 class="text-primary-blue mb-2 md:mb-4">Email Us At:</h3>
        <p class="flex items-center space-x-2 font-medium">
          <Image src={EmailIcon} alt="Email Icon" class="w-5 md:w-6 inline-block" />
          <a href="mailto:info@nixxontech.com">info@nixxontech.com</a>
        </p>
      </div>
      <div class="contact-detail-item">
        <h3 class="text-primary-blue mb-2 md:mb-4">Visit Us At:</h3>
        <p class="flex items-center space-x-2 font-medium">
          <Image
            src={LocationIcon}
            alt="Location Icon"
            class="w-5 md:w-6 inline-block"
          />
          <span> Troy St. Ste B, Dothan, AL 36303 </span>
        </p>
      </div>
    </div>
    <div>
      <p class="text-base md:text-[18px] text-primary-blue font-semibold mb-2 md:mb-4" id="social-heading">Follow Us on:</p>
      <div class="flex space-x-4" id="social-icons-container">
        <Image src={FacebookIcon} alt="Facebook" class="w-6 md:w-8 social-icon" />
        <Image src={InstagramIcon} alt="Instagram" class="w-6 md:w-8 social-icon" />
        <Image src={LinkedInIcon} alt="LinkedIn" class="w-6 md:w-8 social-icon" />
        <Image src={PinterestIcon} alt="Pinterest" class="w-6 md:w-8 social-icon" />
        <Image src={YoutubeIcon} alt="Youtube" class="w-6 md:w-8 social-icon" />
      </div>
    </div>
  </div>
  <Image src={Art} alt="Contact Us" class="w-full max-w-[250px] md:max-w-none md:w-96" id="contact-illustration" />
</section>

